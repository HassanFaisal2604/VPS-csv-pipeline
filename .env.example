# Per-box courier config. Copy to .env (same folder) and edit - .env is
# gitignored, so nightly `git pull` never touches it.

# REQUIRED: this box's name; becomes the server-side incoming subfolder.
CSV_SERVER=SV1

# Everything below is optional - defaults shown.
# Where the bot writes its CSVs. MUST be a Windows-style path (the script
# converts to rsync's cygwin form by itself - do NOT put /cygdrive/ here).
#CSV_RESULTS=C:/Results

# user@host of the ingest server.
#CSV_DEST_HOST=app@188.245.122.19

# Private key path (setup-vps.ps1 generates this one). A DEDICATED courier
# key - never point this at a personal/admin key (see repo README).
#CSV_SSH_KEY=C:/Users/<you>/.ssh/csv-courier_ed25519

# Log file.
#CSV_LOG=C:/Results/send-csvs.log

# Watermark of the last successful send. Files are KEPT in CSV_RESULTS (never
# deleted after shipping); this file is how the courier avoids re-sending them.
# Default is next to the script (gitignored). Delete it to force a full re-send.
#CSV_STATE=C:/courier/.last-sent

# ssh binary rsync uses. Default: the cygwin ssh bundled with the rsync
# package (REQUIRED - Windows-native OpenSSH breaks the rsync protocol).
# Only set this if your rsync lives somewhere non-standard.
#CSV_SSH_EXE=C:/ProgramData/chocolatey/lib/rsync/tools/ssh.exe
