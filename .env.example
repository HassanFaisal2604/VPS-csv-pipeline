# Per-box courier config. Copy to .env (same folder) and edit - .env is
# gitignored, so nightly `git pull` never touches it.

# REQUIRED: this box's name; becomes the server-side incoming subfolder.
CSV_SERVER=SV1

# Everything below is optional - defaults shown.
# Where the bot writes its CSVs. If rsync says "no such file", use the
# cygwin form: /cygdrive/c/Results
#CSV_RESULTS=C:/Results

# user@host of the ingest server.
#CSV_DEST_HOST=app@188.245.122.19

# Private key path (setup-vps.ps1 generates this one).
#CSV_SSH_KEY=C:/Users/<you>/.ssh/id_ed25519

# Log file.
#CSV_LOG=C:/Results/send-csvs.log
